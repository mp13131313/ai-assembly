# Required: Anthropic API key for all LLM calls (Researcher, Provocateur, Cleaning, Speaker ID).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Required: AssemblyAI API key for ASR + diarization.
# Get one at https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=

# Optional model overrides (defaults are the sensible production choice; only
# override for experiments or cost tuning).
# CLAUDE_MODEL=claude-opus-4-6
# TRANSCRIPTION_SPEAKER_ID_MODEL=claude-sonnet-4-6

# Optional Provocateur knobs (see flows/provocateur_flow.py).
# PROVOCATEUR_THINKING=1
# PROVOCATEUR_FORMULATION_BATCH=4
# PROVOCATEUR_BATCH_WAIT_S=20

# Optional Researcher knob.
# RESEARCHER_THINKING=1
