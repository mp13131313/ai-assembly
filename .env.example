# ============================================================
# AI Assembly monorepo — shared .env
# Place this file at the repo root as .env (mode 0600).
# ============================================================

# ── Shared ──────────────────────────────────────────────────

# Required by both runtime (Researcher, Provocateur, Cleaning, Speaker ID)
# and personas (all generation passes). Get at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Runtime (runtime/) ──────────────────────────────────────

# Required: AssemblyAI API key for ASR + diarization.
# Get one at https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=

# Required for the ingest web app (runtime/ingest/app.py). Shared HTTP Basic
# Auth password. Producers log in as any username (conventionally "producer")
# with this password.
UPLOAD_APP_PASSWORD=

# Optional model overrides (defaults are the sensible production choice).
# CLAUDE_MODEL=claude-opus-4-6
# TRANSCRIPTION_SPEAKER_ID_MODEL=claude-sonnet-4-6

# Optional Provocateur knobs (see runtime/flows/provocateur_flow.py).
# PROVOCATEUR_THINKING=1
# PROVOCATEUR_FORMULATION_BATCH=4
# PROVOCATEUR_BATCH_WAIT_S=20

# Optional Researcher knob.
# RESEARCHER_THINKING=1

# Optional: swap the Stage 0 command for testing. Defaults to
# `python flows/transcription_flow.py`. Set to the fake flow during smoke
# tests to avoid burning credits.
# INGEST_FLOW_CMD=python runtime/ingest/tests/fake_transcription_flow.py

# ── Personas (personas/) ─────────────────────────────────────

# Required: Perplexity API key for Pass 1a (Research Dossier).
# Uses sonar-deep-research. Get at https://www.perplexity.ai/settings/api
# (~$2-4 per voice)
PERPLEXITY_API_KEY=

# Required: Google API key for Pass 1b (Broad Scan) and Pass 7a fallback.
# Uses gemini-2.5-pro. Get at https://aistudio.google.com/apikey (free tier OK)
GOOGLE_API_KEY=

# Required: OpenAI API key for Pass 7a (primary cross-model validation) and
# Pass 3 conditional ChatGPT Deep Research. Uses gpt-4o or latest.
# Get at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: model overrides (defaults are sensible)
# PERPLEXITY_MODEL=sonar-deep-research
# GEMINI_MODEL=gemini-2.5-pro
# OPENAI_MODEL=gpt-4o

# Optional: extended thinking budgets (in tokens)
# PERSONA_THINKING_BUDGET=8000

# Optional: parallelism / batching for Athens-scale runs
# PERSONA_VOICE_BATCH=4
