{
  "$defs": {
    "SourceCitation": {
      "description": "A single citation supporting a claim.",
      "properties": {
        "author": {
          "title": "Author",
          "type": "string"
        },
        "work": {
          "title": "Work",
          "type": "string"
        },
        "year": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Year"
        },
        "page": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Page"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        },
        "tier": {
          "enum": [
            "tier_1_primary",
            "tier_2_scholarly",
            "tier_3_contested"
          ],
          "title": "Tier",
          "type": "string"
        }
      },
      "required": [
        "author",
        "work",
        "tier"
      ],
      "title": "SourceCitation",
      "type": "object"
    }
  },
  "description": "Structured anachronism: modern term + reason excluded + voice-native\nalternative where available.\n\nRicher than the pre-1-arch-03 list[str] format — captures the reason-why\nand the voice-native term if the voice's tradition has one. Backward-compat\npreserved via `LifeScaffold.anachronisms_to_avoid: list[str | AnachronismEntry]`.",
  "properties": {
    "modern_term": {
      "title": "Modern Term",
      "type": "string"
    },
    "reason_excluded": {
      "description": "One-line reason the modern term mis-renders the voice.",
      "title": "Reason Excluded",
      "type": "string"
    },
    "voice_native_alternative": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "The voice's own tradition-specific term if one exists. Example: for 'trauma', voice_native_alternative = 'nadryv' (Dostoevsky) or 'ibtilā'' (Ibn Battuta).",
      "title": "Voice Native Alternative"
    },
    "evidence_tag": {
      "default": "scholarly_consensus",
      "enum": [
        "stated",
        "scholarly_consensus",
        "inference",
        "experiential_reconstruction",
        "projection_warning"
      ],
      "title": "Evidence Tag",
      "type": "string"
    },
    "citations": {
      "items": {
        "$ref": "#/$defs/SourceCitation"
      },
      "title": "Citations",
      "type": "array"
    }
  },
  "required": [
    "modern_term",
    "reason_excluded"
  ],
  "title": "AnachronismEntry",
  "type": "object"
}
