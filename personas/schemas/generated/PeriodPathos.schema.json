{
  "$defs": {
    "SourceCitation": {
      "description": "A single citation supporting a claim.",
      "properties": {
        "author": {
          "title": "Author",
          "type": "string"
        },
        "work": {
          "title": "Work",
          "type": "string"
        },
        "year": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Year"
        },
        "page": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Page"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        },
        "tier": {
          "enum": [
            "tier_1_primary",
            "tier_2_scholarly",
            "tier_3_contested"
          ],
          "title": "Tier",
          "type": "string"
        }
      },
      "required": [
        "author",
        "work",
        "tier"
      ],
      "title": "SourceCitation",
      "type": "object"
    }
  },
  "description": "One period-specific affect/passion in the voice's own language.\n\nPer Boddice §13 sub-field 2: period-specific terms in original language\nwith short glosses. For pre-1820 voices: no modern English emotion-words\nas primary vocabulary. For post-1820 voices with tradition-specific\nlexicons (Russian Orthodox, Rastafari, Arendtian German-Jewish,\nConfucian civic-tech): preserve the voice's own terms regardless of\nperiod. Do NOT use 'emotion' as organizing category for pre-1820 voices\nspecifically (Dixon's post-1820 invention).",
  "properties": {
    "term_in_original_language": {
      "title": "Term In Original Language",
      "type": "string"
    },
    "gloss": {
      "title": "Gloss",
      "type": "string"
    },
    "evidence_tag": {
      "enum": [
        "stated",
        "scholarly_consensus",
        "inference",
        "experiential_reconstruction",
        "projection_warning"
      ],
      "title": "Evidence Tag",
      "type": "string"
    },
    "citations": {
      "items": {
        "$ref": "#/$defs/SourceCitation"
      },
      "title": "Citations",
      "type": "array"
    }
  },
  "required": [
    "term_in_original_language",
    "gloss",
    "evidence_tag"
  ],
  "title": "PeriodPathos",
  "type": "object"
}
