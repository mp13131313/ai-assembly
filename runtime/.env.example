# Required: Anthropic API key for all LLM calls (Researcher, Provocateur, Cleaning, Speaker ID).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Required: AssemblyAI API key for ASR + diarization.
# Get one at https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=

# Optional model overrides (defaults are the sensible production choice; only
# override for experiments or cost tuning).
# CLAUDE_MODEL=claude-opus-4-7
# TRANSCRIPTION_SPEAKER_ID_MODEL=claude-sonnet-4-6

# Optional per-flow model overrides (take precedence over CLAUDE_MODEL).
# Use these when you want to upgrade one flow to Opus without affecting
# the others. If unset, each flow falls back to CLAUDE_MODEL, then to
# its compiled-in default (Sonnet for transcription, Opus for researcher
# and provocateur).
# TRANSCRIPTION_CLAUDE_MODEL=claude-sonnet-4-6
# RESEARCHER_CLAUDE_MODEL=claude-opus-4-7
# PROVOCATEUR_CLAUDE_MODEL=claude-opus-4-7

# Optional Provocateur knobs (see flows/provocateur_flow.py).
# PROVOCATEUR_THINKING=1
# PROVOCATEUR_FORMULATION_BATCH=4
# PROVOCATEUR_BATCH_WAIT_S=20

# Optional Researcher knob.
# RESEARCHER_THINKING=1

# Required for the ingest web app (ingest/app.py). Shared HTTP Basic Auth
# password. Producers log in as any username (conventionally "producer")
# with this password.
UPLOAD_APP_PASSWORD=

# Optional: override the Stage 0 command. DEFAULT (when unset):
# `python flows/transcription_flow.py` — this is what production uses.
# Uncomment the line below ONLY for smoke-testing with the fake flow;
# leaving it enabled in production silently runs the fake pipeline
# and produces stub outputs.
# INGEST_FLOW_CMD=python ingest/tests/fake_transcription_flow.py
</content>